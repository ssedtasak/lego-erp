# Supabase Configuration
# Copy this to .env and fill in your values

# Supabase Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anon Key (safe to expose in client)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role Key (server-side only, never expose)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# LINE LIFF ID
NEXT_PUBLIC_LINE_LIFF_ID=your-liff-id-here

# LINE Channel Access Token (for Messaging API)
LINE_CHANNEL_ACCESS_TOKEN=your-channel-access-token-here

# LINE Notify (optional, for low-stock alerts)
LINE_NOTIFY_TOKEN=your-notify-token-here
